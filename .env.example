# Copiar a .env (local) o cargar como GitHub Secrets (nube). NO commitear .env real.
TGN_USER=tu_usuario_tgn
TGN_PASS=tu_password_tgn
TGN_LOGIN_URL=https://app.theguidenetwork.com/login
TGN_SEARCH_URL=https://app.theguidenetwork.com/bookings

# Google Drive (Foyel): JSON completo de la service account, en una sola línea
GOOGLE_SA_JSON={"type":"service_account", ...}

# Email de aviso (Gmail/Workspace: app password, no la contraseña normal)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alguien@theriverhousegroup.com
SMTP_PASS=app_password_de_16_digitos
